# Currency symbol displayed in the UI
VITE_CURRENCY=$

# Clerk authentication publishable key
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx

# Backend API base URL (your deployed server URL on Vercel)
# Example: https://your-server-app.vercel.app
VITE_API_BASE_URL=https://your-server-app.vercel.app

# TMDB image base URL (optional, defaults to https://image.tmdb.org/t/p/w500)
VITE_TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/original
